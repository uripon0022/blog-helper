<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>楽天ブログ投稿ヘルパー</title>
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <div class="app-shell">
      <header class="hero">
        <div>
          <p class="eyebrow">Rakuten Blog Draft Console</p>
          <h1>楽天ブログ投稿ヘルパー</h1>
          <p class="hero-copy">記事をローカル保存し、楽天ブログの投稿画面へ安全に転送します。公開ボタンは自動で押しません。</p>
        </div>
        <div class="hero-actions">
          <button id="new-article-button" class="button button-secondary" type="button">新規記事</button>
          <button id="save-article-button" class="button" type="button">記事を保存</button>
          <button id="transfer-button" class="button button-accent" type="button">楽天ブログへ転送</button>
        </div>
      </header>

      <main class="layout">
        <aside class="sidebar">
          <section class="panel">
            <div class="panel-head">
              <h2>記事一覧</h2>
              <button id="duplicate-article-button" class="ghost-button" type="button">複製</button>
            </div>
            <div class="sidebar-tools">
              <select id="article-status-filter">
                <option value="">すべての状態</option>
              </select>
              <button id="delete-article-button" class="ghost-button danger" type="button">削除</button>
            </div>
            <div id="article-list" class="list-block"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>テンプレート</h2>
              <button id="new-template-button" class="ghost-button" type="button">新規</button>
            </div>
            <div class="sidebar-tools">
              <button id="apply-template-button" class="ghost-button" type="button">記事へ反映</button>
              <button id="delete-template-button" class="ghost-button danger" type="button">削除</button>
            </div>
            <div id="template-list" class="list-block compact"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>バックアップ</h2>
            </div>
            <div class="stack">
              <button id="export-button" class="button button-secondary" type="button">JSONを書き出す</button>
              <label class="file-input-label">
                JSONから復元する
                <input id="import-input" type="file" accept="application/json">
              </label>
              <p class="subtle">ブラウザのサイトデータ削除で保存内容が消える可能性があります。定期的なバックアップを推奨します。</p>
            </div>
          </section>
        </aside>

        <section class="editor-column">
          <section class="panel">
            <div class="panel-head">
              <h2>記事編集</h2>
              <div id="save-indicator" class="save-indicator">未保存</div>
            </div>
            <form id="article-form" class="form-grid">
              <label class="field full">
                <span>記事タイトル</span>
                <input id="article-title" name="title" type="text" placeholder="例: おすすめ商品の使い心地をレビュー">
              </label>

              <label class="field full">
                <span>記事本文</span>
                <textarea id="article-body" name="body" rows="14" placeholder="本文を入力してください"></textarea>
              </label>

              <label class="field">
                <span>カテゴリ</span>
                <input id="article-category" name="category" type="text" placeholder="例: お買い物レビュー">
              </label>

              <label class="field">
                <span>テーマ</span>
                <input id="article-theme" name="theme" type="text" placeholder="例: 楽天市場おすすめ">
              </label>

              <label class="field">
                <span>投稿予定日時</span>
                <input id="article-scheduled-at" name="scheduledAt" type="datetime-local">
              </label>

              <label class="field">
                <span>状態</span>
                <select id="article-status" name="status"></select>
              </label>

              <label class="field inline-toggle">
                <input id="article-pr-required" name="prRequired" type="checkbox">
                <span>PR表記を自動挿入する</span>
              </label>

              <label class="field">
                <span>PR表記</span>
                <input id="article-pr-text" name="prText" type="text" placeholder="例: ※この記事にはPRが含まれます。">
              </label>

              <label class="field full">
                <span>記事冒頭の定型文</span>
                <textarea id="article-intro-text" name="introText" rows="4" placeholder="冒頭に自動で追加する定型文"></textarea>
              </label>

              <label class="field full">
                <span>記事末尾の定型文</span>
                <textarea id="article-outro-text" name="outroText" rows="4" placeholder="末尾に自動で追加する定型文"></textarea>
              </label>

              <label class="field full">
                <span>楽天アフィリエイトリンク</span>
                <input id="article-affiliate-link" name="affiliateLink" type="url" placeholder="https://...">
              </label>

              <label class="field">
                <span>商品名</span>
                <input id="article-product-name" name="productName" type="text" placeholder="例: 充電式ハンディファン">
              </label>

              <label class="field">
                <span>管理用メモ</span>
                <input id="article-memo" name="memo" type="text" placeholder="社内メモ、修正方針など">
              </label>

              <label class="field full">
                <span>記事要約</span>
                <textarea id="article-summary" name="summary" rows="3" placeholder="必要に応じて本文冒頭に使える要約"></textarea>
              </label>

              <label class="field">
                <span>検索結果向け説明文</span>
                <textarea id="article-search-description" name="searchDescription" rows="3" placeholder="ツール内保管用"></textarea>
              </label>

              <label class="field">
                <span>SNS投稿用紹介文</span>
                <textarea id="article-sns-description" name="snsDescription" rows="3" placeholder="ツール内保管用"></textarea>
              </label>
            </form>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>テンプレート編集</h2>
              <button id="save-template-button" class="ghost-button" type="button">テンプレート保存</button>
            </div>
            <form id="template-form" class="form-grid compact-grid">
              <label class="field">
                <span>テンプレート名</span>
                <input id="template-name" name="name" type="text" placeholder="例: 商品紹介記事">
              </label>
              <label class="field">
                <span>初期カテゴリ</span>
                <input id="template-default-category" name="defaultCategory" type="text">
              </label>
              <label class="field">
                <span>初期テーマ</span>
                <input id="template-default-theme" name="defaultTheme" type="text">
              </label>
              <label class="field">
                <span>PR表記</span>
                <input id="template-pr-text" name="prText" type="text">
              </label>
              <label class="field full">
                <span>冒頭文</span>
                <textarea id="template-intro-text" name="introText" rows="3"></textarea>
              </label>
              <label class="field full">
                <span>見出し構成</span>
                <textarea id="template-heading-template" name="headingTemplate" rows="4" placeholder="例: # 商品の特徴&#10;# 使って感じたこと&#10;# まとめ"></textarea>
              </label>
              <label class="field full">
                <span>末尾文</span>
                <textarea id="template-outro-text" name="outroText" rows="3"></textarea>
              </label>
              <label class="field full">
                <span>定型リンク</span>
                <input id="template-fixed-link" name="fixedLink" type="url" placeholder="https://...">
              </label>
              <label class="field full">
                <span>注意書き</span>
                <textarea id="template-note" name="note" rows="3"></textarea>
              </label>
            </form>
          </section>
        </section>

        <aside class="preview-column">
          <section class="panel">
            <div class="panel-head">
              <h2>転送設定</h2>
            </div>
            <form id="settings-form" class="stack">
              <label class="field">
                <span>楽天ブログ投稿画面URL</span>
                <input id="settings-editor-url" name="rakutenEditorUrl" type="url" placeholder="例: https://plaza.rakuten.co.jp/...">
              </label>
              <label class="field">
                <span>転送モード</span>
                <select id="settings-transfer-mode" name="transferMode">
                  <option value="draft">下書き保存まで試行</option>
                  <option value="fill-only">保存直前で止める</option>
                </select>
              </label>
              <button id="save-settings-button" class="button button-secondary" type="button">設定を保存</button>
              <p class="subtle">投稿画面URLが未設定のときは楽天ブログのトップを開きます。新規投稿URLが分かる場合は設定しておくと安定します。</p>
            </form>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>転送前チェック</h2>
            </div>
            <div id="validation-list" class="validation-list"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>簡易プレビュー</h2>
            </div>
            <article id="preview" class="preview-card"></article>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>転送ログ</h2>
            </div>
            <div id="transfer-log" class="transfer-log">まだ転送していません。</div>
          </section>
        </aside>
      </main>
    </div>

    <script src="app.js"></script>
  </body>
</html>
