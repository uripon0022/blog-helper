<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>楽天ブログ投稿ヘルパー</title>
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <div class="app-shell">
      <header class="hero">
        <div>
          <p class="eyebrow">Rakuten Blog Draft Console</p>
          <h1>楽天ブログ投稿ヘルパー</h1>
          <p class="hero-copy">記事をローカル保存し、楽天ブログの投稿画面へ安全に転送します。公開ボタンは自動で押しません。</p>
        </div>
        <div class="hero-actions">
          <button id="new-article-button" class="button button-secondary" type="button">新規記事</button>
          <button id="save-article-button" class="button" type="button">記事を保存</button>
          <button id="transfer-button" class="button button-accent" type="button">楽天ブログへ転送</button>
        </div>
      </header>

      <main class="layout">
        <aside class="sidebar">
          <section class="panel">
            <div class="panel-head">
              <h2>記事一覧</h2>
              <button id="duplicate-article-button" class="ghost-button" type="button">複製</button>
            </div>
            <div class="sidebar-tools">
              <select id="article-status-filter">
                <option value="">すべての状態</option>
              </select>
              <button id="delete-article-button" class="ghost-button danger" type="button">削除</button>
            </div>
            <div id="article-list" class="list-block"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>テンプレート</h2>
              <button id="new-template-button" class="ghost-button" type="button">新規</button>
            </div>
            <div class="sidebar-tools">
              <button id="apply-template-button" class="ghost-button" type="button">記事へ反映</button>
              <button id="delete-template-button" class="ghost-button danger" type="button">削除</button>
            </div>
            <div id="template-list" class="list-block compact"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>バックアップ</h2>
            </div>
            <div class="stack">
              <button id="export-button" class="button button-secondary" type="button">JSONを書き出す</button>
              <label class="file-input-label">
                JSONから復元する
                <input id="import-input" type="file" accept="application/json">
              </label>
              <p class="subtle">ブラウザのサイトデータ削除で保存内容が消える可能性があります。定期的なバックアップを推奨します。</p>
            </div>
          </section>
        </aside>

        <section class="editor-column">
          <section class="panel">
            <div class="panel-head">
              <h2>記事編集</h2>
              <div id="save-indicator" class="save-indicator">未保存</div>
            </div>
            <form id="article-form" class="form-grid">
              <label class="field full">
                <span>記事タイトル</span>
                <input id="article-title" name="title" type="text" placeholder="例: おすすめ商品の使い心地をレビュー">
              </label>

              <label class="field full">
                <span>記事本文</span>
                <textarea id="article-body" name="body" rows="14" placeholder="本文を入力してください"></textarea>
              </label>

              <label class="field">
                <span>カテゴリ</span>
                <input id="article-category" name="category" type="text" placeholder="例: お買い物レビュー">
              </label>

              <label class="field">
                <span>テーマ</span>
                <input id="article-theme" name="theme" type="text" placeholder="例: 楽天市場おすすめ">
              </label>

              <label class="field">
                <span>投稿予定日時</span>
                <input id="article-scheduled-at" name="scheduledAt" type="datetime-local">
              </label>

              <label class="field">
                <span>状態</span>
                <select id="article-status" name="status"></select>
              </label>

              <label class="field inline-toggle">
                <input id="article-pr-required" name="prRequired" type="checkbox">
                <span>PR表記を自動挿入する</span>
